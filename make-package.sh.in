#!/bin/bash

mkdir -p install/DEBIAN/
file="install/DEBIAN/control"

>$file
echo "Package: Frisket-pdf" >>$file
echo "Version: ${PDF4QT_VERSION}" >>$file
echo "Section: base" >>$file
echo "Priority: optional" >>$file
echo "Architecture: amd64" >>$file
echo "Maintainer: Michael Berry" >>$file
echo "Description: Frisket-PDF: PDF editor and toolkit based on PDF4QT (Qt, C++)." >>$file
echo "Homepage: https://github.com/mberrys/Frisket-pdf" >>$file
echo "Vcs-Browser: https://github.com/mberrys/Frisket-pdf" >>$file


dpkg-deb --build install

mv install.deb Frisket-pdf-${PDF4QT_VERSION}.deb






